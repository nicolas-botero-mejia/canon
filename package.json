{
  "name": "@nicolas-botero-mejia/canon",
  "version": "0.5.0",
  "description": "Canon — AI-assisted engagement framework",
  "type": "module",
  "bin": {
    "canon": "./bin/cli.mjs",
    "canon-mcp": "./bin/mcp-server.mjs"
  },
  "files": [
    "bin/",
    "lib/",
    "manifest.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "pack-dry": "npm pack --dry-run",
    "test": "node --test test/unit/*.test.mjs",
    "test:integration": "bash test/integration/run.sh",
    "test:hooks": "bash test/hooks/run.sh",
    "test:all": "npm test && npm run test:integration && npm run test:hooks",
    "test:evals": "bash test/evals/run-evals.sh",
    "test:evals:selftest": "npx --yes promptfoo@latest eval -c test/evals/harness-selftest.yaml --no-cache"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "markdownlint": "^0.41.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicolas-botero-mejia/canon.git"
  },
  "bugs": {
    "url": "https://github.com/nicolas-botero-mejia/canon/issues"
  },
  "homepage": "https://github.com/nicolas-botero-mejia/canon#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "framework",
    "consulting",
    "knowledge-management",
    "claude",
    "cursor",
    "ai-workflow"
  ]
}
