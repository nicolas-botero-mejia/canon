{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "bash node_modules/@nicolas-botero-mejia/canon/bin/hook.sh SessionStart"
      }
    ],
    "postToolUse": [
      {
        "command": "bash node_modules/@nicolas-botero-mejia/canon/bin/hook.sh PostToolUse",
        "matcher": "Write|StrReplace"
      }
    ],
    "stop": [
      {
        "command": "bash node_modules/@nicolas-botero-mejia/canon/bin/hook.sh Stop"
      }
    ]
  }
}
